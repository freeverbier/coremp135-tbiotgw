# =============================================================================
# CoreMP135 — IoT Gateway Provisioning Config
# =============================================================================
# Copy this file to .env, fill in your values, then run:
#   sudo ./setup.sh --env-file=.env
#
# WARNING: Never commit .env to git — add it to .gitignore
# =============================================================================

# ----------------------------------------------------------------------------
# ThingsBoard IoT Gateway
# ----------------------------------------------------------------------------
TB_GW_HOST=enermon.energroup.ch
TB_GW_PORT=8883

# Provisioning credentials (from your ThingsBoard instance)
TB_GW_PROVISIONING_DEVICE_KEY=your_provisioning_device_key_here
TB_GW_PROVISIONING_DEVICE_SECRET=your_provisioning_device_secret_here

# Device name on ThingsBoard — auto-set to "coremp135-<eth0-MAC>" by setup.sh.
# Override here only if you want a custom name instead.
# TB_GW_DEVICE_NAME=my-custom-gateway-name

# ----------------------------------------------------------------------------
# Tailscale Reverse VPN
# ----------------------------------------------------------------------------
# Generate a reusable auth key at: https://login.tailscale.com/admin/settings/keys
# Recommended: enable "Reusable" + "Ephemeral" (for auto-cleanup on offline devices)
# or "Reusable" + "Pre-approved" for persistent nodes
TAILSCALE_AUTH_KEY=tskey-auth-XXXXXXXXXXXXXXXX

# Optional: override the Tailscale hostname for this device
# Default: coremp135-<MAC-address>  (e.g. coremp135-d6-03-3f-1e-0b-9f)
# TAILSCALE_HOSTNAME=my-custom-gateway-name

# ----------------------------------------------------------------------------
# Attribute Reporter
# ----------------------------------------------------------------------------
# ThingsBoard HTTPS port for the device HTTP API (default: 443)
# TB_GW_HTTP_PORT=443

# How often device attributes are pushed to ThingsBoard, in seconds (default: 300 = 5 min)
# ATTR_REPORT_INTERVAL=300

# Attributes reported automatically:
#   mac_address, eth0_ip, tailscale_ip, hostname, os_version, tb_gateway_image, uptime

# ----------------------------------------------------------------------------
# Timezone + NTP
# ----------------------------------------------------------------------------
# See full list: timedatectl list-timezones
TIMEZONE=Europe/Zurich

# ----------------------------------------------------------------------------
# Advanced (optional)
# ----------------------------------------------------------------------------
# INSTALL_DIR=/opt/tb-gateway
